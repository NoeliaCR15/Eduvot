<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="760.0" prefWidth="1080.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.controladores.ResultadosController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="page-header">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="page-title" text="Resultados y participacion" />
                                <Label styleClass="page-subtitle" text="Consulta recuentos, participacion y resultados por opcion." wrapText="true" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#volverPanelAdministrador" styleClass="secondary-button" text="Volver" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="22.0" right="22.0" top="20.0" />
                    </padding>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="14.0" styleClass="table-card" prefWidth="420.0">
                            <padding>
                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                            </padding>
                            <children>
                                <Label fx:id="lblListadoEncuestas" styleClass="section-title" text="Encuestas disponibles" />
                                <HBox spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#mostrarEncuestasActivas" styleClass="secondary-button" text="Ver disponibles" />
                                        <Button mnemonicParsing="false" onAction="#mostrarEncuestasArchivadas" styleClass="secondary-button" text="Ver archivadas" />
                                    </children>
                                </HBox>
                                <TableView fx:id="tablaEncuestas" prefHeight="520.0">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colTitulo" prefWidth="210.0" text="Titulo" />
                                        <TableColumn fx:id="colActiva" prefWidth="75.0" text="Activa" />
                                        <TableColumn fx:id="colVotos" prefWidth="75.0" text="Votos" />
                                    </columns>
                                </TableView>
                                <Button mnemonicParsing="false" onAction="#archivarEncuestaSeleccionada" styleClass="module-button" text="Archivar seleccionada" />
                            </children>
                        </VBox>

                        <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox spacing="14.0" styleClass="form-card">
                                    <padding>
                                        <Insets bottom="20.0" left="22.0" right="22.0" top="20.0" />
                                    </padding>
                                    <children>
                                        <Label fx:id="lblEncuestaSeleccionada" styleClass="section-title" text="Selecciona una encuesta" wrapText="true" />
                                        <HBox spacing="14.0">
                                            <children>
                                                <VBox alignment="CENTER" spacing="6.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="info-title" text="Votos" />
                                                        <Label fx:id="lblTotalVotos" styleClass="hero-side-number" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="6.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="info-title" text="Destinatarios" />
                                                        <Label fx:id="lblDestinatarios" styleClass="hero-side-number" text="0" />
                                                    </children>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="6.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="info-title" text="Participacion" />
                                                        <Label fx:id="lblParticipacion" styleClass="hero-side-number" text="0%" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <HBox spacing="18.0">
                                    <children>
                                        <VBox spacing="14.0" styleClass="table-card" prefWidth="360.0">
                                            <padding>
                                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Recuento por opcion" />
                                                <TableView fx:id="tablaResultados" prefHeight="310.0">
                                                    <columns>
                                                        <TableColumn fx:id="colOpcion" prefWidth="240.0" text="Opcion" />
                                                        <TableColumn fx:id="colTotalOpcion" prefWidth="100.0" text="Votos" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>

                                        <VBox spacing="14.0" styleClass="table-card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="section-title" text="Grafica de resultados" />
                                                <BarChart fx:id="graficoResultados" legendVisible="false" prefHeight="310.0">
                                                    <xAxis>
                                                        <CategoryAxis fx:id="ejeOpciones" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <NumberAxis fx:id="ejeVotos" />
                                                    </yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
