<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.controladores.GestionUsuariosController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="page-header">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label styleClass="page-title" text="Gestion de usuarios" />
                                <Label styleClass="page-subtitle" text="Administra las cuentas de acceso de la plataforma EDUVOT." wrapText="true" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#volverPanelAdministrador" styleClass="secondary-button" text="Volver" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="22.0" right="22.0" top="20.0" />
                    </padding>
                </HBox>

                <VBox spacing="18.0" styleClass="form-card">
                    <padding>
                        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                    </padding>
                    <children>
                        <Label styleClass="section-title" text="Datos del usuario" />

                        <HBox alignment="TOP_LEFT" spacing="36.0">
                            <children>
                                <VBox spacing="14.0">
                                    <children>
                                        <HBox spacing="16.0">
                                            <children>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="DNI" />
                                                        <TextField fx:id="txtDni" promptText="DNI del usuario" styleClass="admin-field" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Nombre de usuario" />
                                                        <TextField fx:id="txtNombreUsuario" promptText="Nombre de usuario" styleClass="admin-field" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Contraseña" />
                                                        <TextField fx:id="txtPassword" promptText="Contraseña" styleClass="admin-field" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox alignment="BOTTOM_LEFT" spacing="20.0">
                                            <children>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Curso" />
                                                        <ComboBox fx:id="cmbCurso" editable="true" prefWidth="300.0" promptText="Curso o grupo academico" styleClass="admin-field" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label styleClass="field-label" text="Subcategorias" />
                                                        <MenuButton fx:id="btnSubcategorias" mnemonicParsing="false" prefWidth="300.0" styleClass="admin-field" text="Seleccionar subcategorias" />
                                                    </children>
                                                </VBox>
                                                <CheckBox fx:id="chkAdministrador" text="Es administrador" />
                                                <CheckBox fx:id="chkActivo" selected="true" text="Usuario activo" />
                                            </children>
                                        </HBox>

                                        <VBox fx:id="contenedorFamilia" managed="false" spacing="6.0" visible="false">
                                            <children>
                                                <Label styleClass="field-label" text="Alumno/s vinculados si pertenece a Familia o tutor" />
                                                <MenuButton fx:id="btnAlumnosFamilia" mnemonicParsing="false" prefWidth="620.0" styleClass="admin-field" text="Seleccionar alumno/s" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <VBox spacing="10.0" styleClass="user-actions">
                                    <children>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#editarUsuario" prefWidth="125.0" styleClass="secondary-button" text="Editar" />
                                                <Button mnemonicParsing="false" onAction="#eliminarUsuario" prefWidth="125.0" styleClass="secondary-button" text="Eliminar" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#limpiarCampos" prefWidth="260.0" styleClass="secondary-button" text="Limpiar" />
                                            </children>
                                        </HBox>
                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#agregarUsuario" styleClass="module-button" text="Agregar" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="table-card">
                    <padding>
                        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                    </padding>
                    <children>
                        <Label styleClass="section-title" text="Buscar usuarios" />
                        <HBox spacing="12.0">
                            <children>
                                <TextField fx:id="txtBuscarUsuario" promptText="Buscar por DNI o nombre" styleClass="admin-field" />
                                <Button mnemonicParsing="false" onAction="#buscarUsuarios" styleClass="module-button" text="Buscar" />
                                <Button mnemonicParsing="false" onAction="#limpiarBusqueda" styleClass="secondary-button" text="Limpiar busqueda" />
                            </children>
                        </HBox>
                        <TableView fx:id="tablaUsuarios" prefHeight="380.0">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
                                <TableColumn fx:id="colDni" prefWidth="170.0" text="DNI" />
                                <TableColumn fx:id="colNombreUsuario" prefWidth="210.0" text="Usuario" />
                                <TableColumn fx:id="colGrupo" prefWidth="170.0" text="Curso" />
                                <TableColumn fx:id="colAdministrador" prefWidth="130.0" text="Admin" />
                                <TableColumn fx:id="colActivo" prefWidth="130.0" text="Activo" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
